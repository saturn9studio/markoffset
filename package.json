{
  "name": "@saturn9/markoffset",
  "version": "0.2.1",
  "description": "Fast, plugin-based Markdown parser",
  "license": "MIT",
  "author": "Saturn9 LLC",
  "homepage": "https://github.com/saturn9studio/markoffset#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saturn9studio/markoffset.git"
  },
  "bugs": {
    "url": "https://github.com/saturn9studio/markoffset/issues"
  },
  "keywords": [
    "markdown",
    "parser",
    "commonmark",
    "gfm",
    "incremental",
    "source-map",
    "tokens"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./incremental": {
      "types": "./dist/incremental.d.ts",
      "import": "./dist/incremental.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    },
    "./plugins/block": {
      "types": "./dist/plugins/block/index.d.ts",
      "import": "./dist/plugins/block/index.js"
    },
    "./plugins/block/*": {
      "types": "./dist/plugins/block/*.d.ts",
      "import": "./dist/plugins/block/*.js"
    },
    "./plugins/inline": {
      "types": "./dist/plugins/inline/index.d.ts",
      "import": "./dist/plugins/inline/index.js"
    },
    "./plugins/inline/*": {
      "types": "./dist/plugins/inline/*.d.ts",
      "import": "./dist/plugins/inline/*.js"
    },
    "./plugins/footnotes": {
      "types": "./dist/plugins/footnotes.d.ts",
      "import": "./dist/plugins/footnotes.js"
    },
    "./plugins/references": {
      "types": "./dist/plugins/references.d.ts",
      "import": "./dist/plugins/references.js"
    },
    "./plugins/tagfilter": {
      "types": "./dist/plugins/tagfilter.d.ts",
      "import": "./dist/plugins/tagfilter.js"
    },
    "./presets/commonmark": {
      "types": "./dist/presets/commonmark.d.ts",
      "import": "./dist/presets/commonmark.js"
    },
    "./presets/gfm": {
      "types": "./dist/presets/gfm.d.ts",
      "import": "./dist/presets/gfm.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "vitest run",
    "verify": "npm run build && npm run test",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run test",
    "update-spec-fixtures": "node scripts/update-spec-fixtures.cjs",
    "bench": "tsx test/benchmark/bench.ts",
    "bench:incremental": "tsx test/benchmark/incremental-bench.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "markdown-it": "^14.1.0",
    "marked": "^12.0.0",
    "tinybench": "^2.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "entities": "^4.5.0"
  }
}
