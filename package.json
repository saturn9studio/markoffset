{
  "name": "@saturn9/markoffset",
  "version": "0.1.0",
  "description": "Fast, plugin-based Markdown parser",
  "license": "MIT",
  "author": "Saturn9 LLC",
  "homepage": "https://github.com/saturn9studio/markoffset#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saturn9studio/markoffset.git"
  },
  "bugs": {
    "url": "https://github.com/saturn9studio/markoffset/issues"
  },
  "keywords": [
    "markdown",
    "parser",
    "commonmark",
    "gfm",
    "incremental",
    "source-map",
    "tokens"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "require": "./dist/core/index.js",
      "default": "./dist/core/index.js"
    },
    "./incremental": {
      "types": "./dist/incremental.d.ts",
      "require": "./dist/incremental.js",
      "default": "./dist/incremental.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "require": "./dist/plugins/index.js",
      "default": "./dist/plugins/index.js"
    },
    "./plugins/block": {
      "types": "./dist/plugins/block/index.d.ts",
      "require": "./dist/plugins/block/index.js",
      "default": "./dist/plugins/block/index.js"
    },
    "./plugins/block/*": {
      "types": "./dist/plugins/block/*.d.ts",
      "require": "./dist/plugins/block/*.js",
      "default": "./dist/plugins/block/*.js"
    },
    "./plugins/inline": {
      "types": "./dist/plugins/inline/index.d.ts",
      "require": "./dist/plugins/inline/index.js",
      "default": "./dist/plugins/inline/index.js"
    },
    "./plugins/inline/*": {
      "types": "./dist/plugins/inline/*.d.ts",
      "require": "./dist/plugins/inline/*.js",
      "default": "./dist/plugins/inline/*.js"
    },
    "./plugins/footnotes": {
      "types": "./dist/plugins/footnotes.d.ts",
      "require": "./dist/plugins/footnotes.js",
      "default": "./dist/plugins/footnotes.js"
    },
    "./plugins/references": {
      "types": "./dist/plugins/references.d.ts",
      "require": "./dist/plugins/references.js",
      "default": "./dist/plugins/references.js"
    },
    "./plugins/tagfilter": {
      "types": "./dist/plugins/tagfilter.d.ts",
      "require": "./dist/plugins/tagfilter.js",
      "default": "./dist/plugins/tagfilter.js"
    },
    "./presets/commonmark": {
      "types": "./dist/presets/commonmark.d.ts",
      "require": "./dist/presets/commonmark.js",
      "default": "./dist/presets/commonmark.js"
    },
    "./presets/gfm": {
      "types": "./dist/presets/gfm.d.ts",
      "require": "./dist/presets/gfm.js",
      "default": "./dist/presets/gfm.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build && npm run test -- --runInBand",
    "update-spec-fixtures": "node scripts/update-spec-fixtures.js",
    "bench": "ts-node test/benchmark/bench.ts",
    "bench:incremental": "ts-node test/benchmark/incremental-bench.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "markdown-it": "^14.1.0",
    "marked": "^12.0.0",
    "tinybench": "^2.9.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "entities": "^4.5.0"
  }
}
